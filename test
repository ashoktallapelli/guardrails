def _process_image_and_redact(raw: bytes, user_text: str) -> Dict[str, Any]:
    """
    Shared core pipeline for both endpoints:
    - validate + sanitize image
    - OCR with boxes
    - PII text detection
    - image redaction (PII)
    - policy decision
    Returns dict with everything needed.
    """
    img = safe_open_image(raw)
    meta_in = validate_image(img, raw)

    sanitized_bytes, sanitize_info = strip_metadata_and_reencode(img)
    sanitized_hash = sha256_bytes(sanitized_bytes)

    s_img = safe_open_image(sanitized_bytes)

    # OCR with boxes (needed for redaction)
    ocr_res = ocr_with_boxes(s_img)
    ocr_text = ocr_res.get("text", "")
    tokens = ocr_res.get("tokens", [])

    # PII detection in text fields
    pii_user = detect_pii_text(user_text)
    pii_ocr = detect_pii_text(ocr_text)
    pii_entities_all = (pii_user.get("entities", []) + pii_ocr.get("entities", []))

    # PII redaction on image using OCR boxes
    pii_boxes = find_pii_boxes_from_tokens(tokens)
    redacted_img_bytes = None
    redacted_sha = None

    if pii_boxes:
        redacted_img = redact_image(s_img, pii_boxes)
        redacted_img_bytes = pil_to_png_bytes(redacted_img)
        redacted_sha = sha256_bytes(redacted_img_bytes)

    # Policy detectors
    denied_topics = detect_denied_topics(ocr_text, user_text)
    sensitive_policy_text = detect_sensitive_policy_text(ocr_text)

    signals = {
        "denied_topics": {"enabled": denied_topics.get("enabled", False), "hits": denied_topics.get("hits", [])},
        "sensitive_policy_text": {"enabled": sensitive_policy_text.get("enabled", False), "hits": sensitive_policy_text.get("hits", []), "action": sensitive_policy_text.get("action")},
        "pii_user": pii_user,
        "pii_ocr": pii_ocr,
        "pii_any": {"enabled": True, "entities": pii_entities_all},
        "pii_image_boxes": [
            {"type": b["type"], "left": b["left"], "top": b["top"], "right": b["right"], "bottom": b["bottom"]}
            for b in pii_boxes
        ],
        "redacted_image_sha256": redacted_sha
    }

    decision, actions = policy_decide(signals)

    # include redacted image as base64 only if enabled (debugging)
    red_cfg = POLICY.get("pii_image_redaction", {})
    if red_cfg.get("return_redacted_image_base64", False) and redacted_img_bytes:
        actions["redacted_image_base64"] = base64.b64encode(redacted_img_bytes).decode("ascii")

    results = {
        "validate_image": {"is_pass": True, "details": meta_in},
        "ocr": {
            "enabled": ocr_res.get("enabled", False),
            "is_error": ocr_res.get("is_error", False),
            "message": ocr_res.get("message"),
            "text_len": ocr_res.get("text_len", 0),
            "text": ocr_text if POLICY.get("logging", {}).get("log_ocr_text", False) else None
        },
        "denied_topics": denied_topics,
        "sensitive_policy_text": sensitive_policy_text,
        "pii_user": {"entities": pii_user.get("entities", []), "sanitized_text": pii_user.get("sanitized_text")},
        "pii_ocr": {"entities": pii_ocr.get("entities", []), "sanitized_text": pii_ocr.get("sanitized_text")},
        "pii_image_boxes": signals["pii_image_boxes"],
    }

    return {
        "meta_in": meta_in,
        "sanitized_bytes": sanitized_bytes,
        "sanitized_sha256": sanitized_hash,
        "sanitize_info": sanitize_info,
        "ocr_res": ocr_res,
        "ocr_text": ocr_text,
        "decision": decision,
        "actions": actions,
        "results": results,
        "redacted_img_bytes": redacted_img_bytes,
        "redacted_sha256": redacted_sha
    }


@app.post("/v1/guardrails/image", response_model=GuardrailResult)
async def guardrail_image(
    image: UploadFile = File(...),
    user_text: str = Form(default="")
):
    t0 = time.time()
    raw = await image.read()
    raw_hash = sha256_bytes(raw)

    out = _process_image_and_redact(raw, user_text)

    sanitized = {
        "input_sha256": raw_hash,
        "sanitized_sha256": out["sanitized_sha256"],
        "input_bytes": len(raw),
        **out["sanitize_info"],
    }
    if out["redacted_sha256"]:
        sanitized["redacted_sha256"] = out["redacted_sha256"]

    return GuardrailResult(
        decision=out["decision"],
        is_safe=bool(out["actions"].get("is_safe", False)),
        results=out["results"],
        actions=out["actions"],
        sanitized=sanitized,
        meta={
            "processing_ms": int((time.time() - t0) * 1000),
            "gateway_version": app.version
        }
    )


@app.post("/v1/guardrails/image/redacted")
async def guardrail_image_redacted(
    image: UploadFile = File(...),
    user_text: str = Form(default="")
):
    """
    Returns the REDACTED PNG image bytes (or sanitized PNG if no redaction needed).
    Use this in automated tests:
      curl -X POST ... --output redacted.png
    """
    raw = await image.read()
    out = _process_image_and_redact(raw, user_text)

    if out["redacted_img_bytes"]:
        return Response(content=out["redacted_img_bytes"], media_type="image/png")

    # If no redaction, return sanitized image
    return Response(content=out["sanitized_bytes"], media_type="image/png")

